        .logo-icon svg { width: 22px; height: 22px; }
        .header-actions { display: flex; gap: 8px; }
        .icon-btn { width: 42px; height: 42px; border-radius: 12px; border: none; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.2s; }
