        .nav-section-title { font-size: 0.75rem; color: var(--text-muted); font-weight: 700; letter-spacing: 1.5px; margin-bottom: 20px; text-transform: uppercase; }
        .nav-links { display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px; }
