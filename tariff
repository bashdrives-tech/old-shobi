            background: #ffffff; 
            border-radius: var(--border-radius-lg); 
            padding: 35px 24px 40px; 
            color: var(--text-dark); 
            margin: 10px 15px 30px 15px; 
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15); 
